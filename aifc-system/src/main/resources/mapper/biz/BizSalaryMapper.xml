<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.aifc.system.mapper.biz.BizSalaryMapper">

    <resultMap id="BizSalaryResult" type="com.aifc.system.domain.biz.BizSalary">
        <result property="id" column="id" />
        <result property="companyId" column="company_id" />
        <result property="reportMonth" column="report_month" />
        <result property="employeeName" column="employee_name" />
        <result property="salaryAmount" column="salary_amount" />
        <result property="is5000" column="is_5000" />
        <result property="taxDeducted" column="tax_deducted" />
        <result property="createTime" column="create_time" />
    </resultMap>

    <sql id="selectBizSalaryVo">
        select id, company_id, report_month, employee_name, salary_amount, is_5000, tax_deducted, create_time
        from biz_salary
    </sql>

    <select id="selectBizSalaryById" parameterType="Long" resultMap="BizSalaryResult">
        <include refid="selectBizSalaryVo"/>
        where id = #{id}
    </select>

    <select id="selectBizSalaryList" parameterType="com.aifc.system.domain.biz.BizSalary" resultMap="BizSalaryResult">
        <include refid="selectBizSalaryVo"/>
        <where>
            <if test="companyId != null">and company_id = #{companyId}</if>
            <if test="params.allowedCompanyIds != null and params.allowedCompanyIds.size() > 0">
                and company_id in
                <foreach item="cid" collection="params.allowedCompanyIds" open="(" separator="," close=")">
                    #{cid}
                </foreach>
            </if>
            <if test="reportMonth != null and reportMonth != ''">and report_month = #{reportMonth}</if>
            <if test="employeeName != null and employeeName != ''">and employee_name like concat('%', #{employeeName}, '%')</if>
            <if test="is5000 != null">and is_5000 = #{is5000}</if>
        </where>
        order by id desc
    </select>

    <insert id="insertBizSalary" parameterType="com.aifc.system.domain.biz.BizSalary" useGeneratedKeys="true" keyProperty="id">
        insert into biz_salary
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="companyId != null">company_id,</if>
            <if test="reportMonth != null and reportMonth != ''">report_month,</if>
            <if test="employeeName != null and employeeName != ''">employee_name,</if>
            <if test="salaryAmount != null">salary_amount,</if>
            <if test="is5000 != null">is_5000,</if>
            <if test="taxDeducted != null">tax_deducted,</if>
            <if test="createTime != null">create_time,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="companyId != null">#{companyId},</if>
            <if test="reportMonth != null and reportMonth != ''">#{reportMonth},</if>
            <if test="employeeName != null and employeeName != ''">#{employeeName},</if>
            <if test="salaryAmount != null">#{salaryAmount},</if>
            <if test="is5000 != null">#{is5000},</if>
            <if test="taxDeducted != null">#{taxDeducted},</if>
            <if test="createTime != null">#{createTime},</if>
        </trim>
    </insert>

    <update id="updateBizSalary" parameterType="com.aifc.system.domain.biz.BizSalary">
        update biz_salary
        <set>
            <if test="reportMonth != null and reportMonth != ''">report_month = #{reportMonth},</if>
            <if test="employeeName != null and employeeName != ''">employee_name = #{employeeName},</if>
            <if test="salaryAmount != null">salary_amount = #{salaryAmount},</if>
            <if test="is5000 != null">is_5000 = #{is5000},</if>
            <if test="taxDeducted != null">tax_deducted = #{taxDeducted},</if>
        </set>
        where id = #{id}
    </update>

    <delete id="deleteBizSalaryById" parameterType="Long">
        delete from biz_salary where id = #{id}
    </delete>

    <delete id="deleteBizSalaryByIds" parameterType="Long">
        delete from biz_salary where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

</mapper>

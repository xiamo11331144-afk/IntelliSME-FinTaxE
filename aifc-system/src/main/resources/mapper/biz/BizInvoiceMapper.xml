<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.aifc.system.mapper.biz.BizInvoiceMapper">

    <resultMap id="BizInvoiceResult" type="com.aifc.system.domain.biz.BizInvoice">
        <result property="id" column="id" />
        <result property="companyId" column="company_id" />
        <result property="reportMonth" column="report_month" />
        <result property="invoiceCode" column="invoice_code" />
        <result property="invoiceNo" column="invoice_no" />
        <result property="amount" column="amount" />
        <result property="taxAmount" column="tax_amount" />
        <result property="invoiceDate" column="invoice_date" />
        <result property="sellerName" column="seller_name" />
        <result property="buyerName" column="buyer_name" />
        <result property="goodsName" column="goods_name" />
        <result property="isInteger" column="is_integer" />
        <result property="isSeries" column="is_series" />
        <result property="fileUrl" column="file_url" />
        <result property="fileType" column="file_type" />
        <result property="status" column="status" />
        <result property="createTime" column="create_time" />
        <result property="updateTime" column="update_time" />
    </resultMap>

    <sql id="selectBizInvoiceVo">
        select id, company_id, report_month, invoice_code, invoice_no, amount, tax_amount,
               invoice_date, seller_name, buyer_name, goods_name, is_integer, is_series,
               file_url, file_type, status, create_time, update_time
        from biz_invoice
    </sql>

    <select id="selectBizInvoiceById" parameterType="Long" resultMap="BizInvoiceResult">
        <include refid="selectBizInvoiceVo"/>
        where id = #{id}
    </select>

    <select id="selectBizInvoiceList" parameterType="com.aifc.system.domain.biz.BizInvoice" resultMap="BizInvoiceResult">
        <include refid="selectBizInvoiceVo"/>
        <where>
            and not exists (
                select 1 from biz_voucher v where v.related_invoice_id = biz_invoice.id
            )
            <if test="companyId != null">and company_id = #{companyId}</if>
            <if test="params.allowedCompanyIds != null and params.allowedCompanyIds.size() > 0">
                and company_id in
                <foreach item="cid" collection="params.allowedCompanyIds" open="(" separator="," close=")">
                    #{cid}
                </foreach>
            </if>
            <if test="reportMonth != null and reportMonth != ''">and report_month = #{reportMonth}</if>
            <if test="invoiceCode != null and invoiceCode != ''">and invoice_code like concat('%', #{invoiceCode}, '%')</if>
            <if test="invoiceNo != null and invoiceNo != ''">and invoice_no like concat('%', #{invoiceNo}, '%')</if>
            <if test="sellerName != null and sellerName != ''">and seller_name like concat('%', #{sellerName}, '%')</if>
            <if test="buyerName != null and buyerName != ''">and buyer_name like concat('%', #{buyerName}, '%')</if>
            <if test="goodsName != null and goodsName != ''">and goods_name like concat('%', #{goodsName}, '%')</if>
            <if test="fileType != null and fileType != ''">and file_type = #{fileType}</if>
            <if test="status != null">and status = #{status}</if>
        </where>
        order by id desc
    </select>

    <insert id="insertBizInvoice" parameterType="com.aifc.system.domain.biz.BizInvoice" useGeneratedKeys="true" keyProperty="id">
        insert into biz_invoice
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="companyId != null">company_id,</if>
            <if test="reportMonth != null and reportMonth != ''">report_month,</if>
            <if test="invoiceCode != null and invoiceCode != ''">invoice_code,</if>
            <if test="invoiceNo != null and invoiceNo != ''">invoice_no,</if>
            <if test="amount != null">amount,</if>
            <if test="taxAmount != null">tax_amount,</if>
            <if test="invoiceDate != null">invoice_date,</if>
            <if test="sellerName != null and sellerName != ''">seller_name,</if>
            <if test="buyerName != null and buyerName != ''">buyer_name,</if>
            <if test="goodsName != null and goodsName != ''">goods_name,</if>
            <if test="isInteger != null">is_integer,</if>
            <if test="isSeries != null">is_series,</if>
            <if test="fileUrl != null and fileUrl != ''">file_url,</if>
            <if test="fileType != null and fileType != ''">file_type,</if>
            <if test="status != null">status,</if>
            <if test="createTime != null">create_time,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="companyId != null">#{companyId},</if>
            <if test="reportMonth != null and reportMonth != ''">#{reportMonth},</if>
            <if test="invoiceCode != null and invoiceCode != ''">#{invoiceCode},</if>
            <if test="invoiceNo != null and invoiceNo != ''">#{invoiceNo},</if>
            <if test="amount != null">#{amount},</if>
            <if test="taxAmount != null">#{taxAmount},</if>
            <if test="invoiceDate != null">#{invoiceDate},</if>
            <if test="sellerName != null and sellerName != ''">#{sellerName},</if>
            <if test="buyerName != null and buyerName != ''">#{buyerName},</if>
            <if test="goodsName != null and goodsName != ''">#{goodsName},</if>
            <if test="isInteger != null">#{isInteger},</if>
            <if test="isSeries != null">#{isSeries},</if>
            <if test="fileUrl != null and fileUrl != ''">#{fileUrl},</if>
            <if test="fileType != null and fileType != ''">#{fileType},</if>
            <if test="status != null">#{status},</if>
            <if test="createTime != null">#{createTime},</if>
        </trim>
    </insert>

    <update id="updateBizInvoice" parameterType="com.aifc.system.domain.biz.BizInvoice">
        update biz_invoice
        <set>
            <if test="companyId != null">company_id = #{companyId},</if>
            <if test="reportMonth != null and reportMonth != ''">report_month = #{reportMonth},</if>
            <if test="invoiceCode != null and invoiceCode != ''">invoice_code = #{invoiceCode},</if>
            <if test="invoiceNo != null and invoiceNo != ''">invoice_no = #{invoiceNo},</if>
            <if test="amount != null">amount = #{amount},</if>
            <if test="taxAmount != null">tax_amount = #{taxAmount},</if>
            <if test="invoiceDate != null">invoice_date = #{invoiceDate},</if>
            <if test="sellerName != null and sellerName != ''">seller_name = #{sellerName},</if>
            <if test="buyerName != null and buyerName != ''">buyer_name = #{buyerName},</if>
            <if test="goodsName != null and goodsName != ''">goods_name = #{goodsName},</if>
            <if test="isInteger != null">is_integer = #{isInteger},</if>
            <if test="isSeries != null">is_series = #{isSeries},</if>
            <if test="fileUrl != null and fileUrl != ''">file_url = #{fileUrl},</if>
            <if test="fileType != null and fileType != ''">file_type = #{fileType},</if>
            <if test="status != null">status = #{status},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </set>
        where id = #{id}
    </update>

    <delete id="deleteBizInvoiceById" parameterType="Long">
        delete from biz_invoice where id = #{id}
    </delete>

    <delete id="deleteBizInvoiceByIds" parameterType="Long">
        delete from biz_invoice where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <insert id="insertBizVoucherByInvoice" parameterType="com.aifc.system.domain.biz.BizInvoice">
        insert into biz_voucher
        (company_id, report_month, voucher_date, amount, type, subject, remark, related_invoice_id, create_time)
        values
        (#{companyId}, #{reportMonth}, #{invoiceDate}, #{amount}, #{params.entryType}, #{params.subject}, #{params.entryRemark}, #{id}, now())
    </insert>

    <select id="countVoucherByInvoiceId" parameterType="Long" resultType="int">
        select count(1) from biz_voucher where related_invoice_id = #{id}
    </select>

    <select id="countInvoiceDuplicate" parameterType="com.aifc.system.domain.biz.BizInvoice" resultType="int">
        select count(1)
        from biz_invoice
        where company_id = #{companyId}
          and invoice_code = #{invoiceCode}
          and invoice_no = #{invoiceNo}
          and status = 1
    </select>

    <select id="countSeriesNeighbor" parameterType="com.aifc.system.domain.biz.BizInvoice" resultType="int">
        select count(1)
        from biz_invoice
        where company_id = #{companyId}
          and report_month = #{reportMonth}
          <if test="invoiceCode != null and invoiceCode != ''">
            and invoice_code = #{invoiceCode}
          </if>
          and invoice_no in (#{params.prevNo}, #{params.nextNo})
    </select>

</mapper>

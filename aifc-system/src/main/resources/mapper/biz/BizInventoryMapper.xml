<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.aifc.system.mapper.biz.BizInventoryMapper">

    <resultMap id="BizInventoryResult" type="com.aifc.system.domain.biz.BizInventory">
        <result property="id" column="id" />
        <result property="companyId" column="company_id" />
        <result property="reportMonth" column="report_month" />
        <result property="bookAmount" column="book_amount" />
        <result property="realAmount" column="real_amount" />
        <result property="diffAmount" column="diff_amount" />
        <result property="diffRate" column="diff_rate" />
        <result property="remark" column="remark" />
        <result property="createTime" column="create_time" />
        <result property="updateTime" column="update_time" />
    </resultMap>

    <sql id="selectBizInventoryVo">
        select id, company_id, report_month, book_amount, real_amount, diff_amount, diff_rate, remark, create_time, update_time
        from biz_inventory
    </sql>

    <select id="selectBizInventoryById" parameterType="Long" resultMap="BizInventoryResult">
        <include refid="selectBizInventoryVo"/>
        where id = #{id}
    </select>

    <select id="selectBizInventoryList" parameterType="com.aifc.system.domain.biz.BizInventory" resultMap="BizInventoryResult">
        <include refid="selectBizInventoryVo"/>
        <where>
            <if test="companyId != null">and company_id = #{companyId}</if>
            <if test="params.allowedCompanyIds != null and params.allowedCompanyIds.size() > 0">
                and company_id in
                <foreach item="cid" collection="params.allowedCompanyIds" open="(" separator="," close=")">
                    #{cid}
                </foreach>
            </if>
            <if test="reportMonth != null and reportMonth != ''">and report_month = #{reportMonth}</if>
        </where>
        order by id desc
    </select>

    <insert id="insertBizInventory" parameterType="com.aifc.system.domain.biz.BizInventory" useGeneratedKeys="true" keyProperty="id">
        insert into biz_inventory
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="companyId != null">company_id,</if>
            <if test="reportMonth != null and reportMonth != ''">report_month,</if>
            <if test="bookAmount != null">book_amount,</if>
            <if test="realAmount != null">real_amount,</if>
            <if test="diffAmount != null">diff_amount,</if>
            <if test="diffRate != null">diff_rate,</if>
            <if test="remark != null">remark,</if>
            <if test="createTime != null">create_time,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="companyId != null">#{companyId},</if>
            <if test="reportMonth != null and reportMonth != ''">#{reportMonth},</if>
            <if test="bookAmount != null">#{bookAmount},</if>
            <if test="realAmount != null">#{realAmount},</if>
            <if test="diffAmount != null">#{diffAmount},</if>
            <if test="diffRate != null">#{diffRate},</if>
            <if test="remark != null">#{remark},</if>
            <if test="createTime != null">#{createTime},</if>
        </trim>
    </insert>

    <update id="updateBizInventory" parameterType="com.aifc.system.domain.biz.BizInventory">
        update biz_inventory
        <set>
            <if test="reportMonth != null and reportMonth != ''">report_month = #{reportMonth},</if>
            <if test="bookAmount != null">book_amount = #{bookAmount},</if>
            <if test="realAmount != null">real_amount = #{realAmount},</if>
            <if test="diffAmount != null">diff_amount = #{diffAmount},</if>
            <if test="diffRate != null">diff_rate = #{diffRate},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </set>
        where id = #{id}
    </update>

    <delete id="deleteBizInventoryById" parameterType="Long">
        delete from biz_inventory where id = #{id}
    </delete>

    <delete id="deleteBizInventoryByIds" parameterType="Long">
        delete from biz_inventory where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

</mapper>
